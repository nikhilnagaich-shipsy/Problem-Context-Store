# =============================================================================
# Problem Context Store — environment variables
# Copy this file to `.env` and fill in any values you've changed from defaults.
# =============================================================================

# -------- Database --------
# Postgres connection string. The `pgvector` extension must be installed.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/problem_context_store?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/problem_context_store?schema=public"

# -------- App --------
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -------- Auth (M2) ---------------------------------------------------------
# Required. Generate one with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-real-secret"

# Required for cookie security in production. Leave commented for localhost.
# AUTH_URL="https://yourdomain.com"

# Magic-link sender — leave RESEND_API_KEY blank during dev to print the
# sign-in link to your `pnpm dev` terminal instead of sending an email.
# RESEND_API_KEY=""
EMAIL_FROM="Problem Context Store <onboarding@resend.dev>"

# Google OAuth — optional. If not set, the "Continue with Google" button is hidden.
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# -------- Queue / Redis (added in M5) ----------------------------------------
# REDIS_URL="redis://localhost:6379"

# -------- LLM (added in M6) --------------------------------------------------
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-sonnet-4-6"
# OPENAI_API_KEY=""
# EMBEDDING_MODEL="text-embedding-3-small"

# -------- Object storage (added in M5) ---------------------------------------
# S3_ENDPOINT=""
# S3_BUCKET=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# -------- Observability (added in M10) ---------------------------------------
# SENTRY_DSN=""
