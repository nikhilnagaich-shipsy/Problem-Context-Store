# =============================================================================
# Problem Context Store — environment variables
# Copy this file to `.env` and fill in any values you've changed from defaults.
# =============================================================================

# -------- Database --------
# Postgres connection string. The `pgvector` extension must be installed
# (use the pgvector/pgvector:pg16 Docker image for local dev).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/problem_context_store?schema=public"

# Direct connection (used by Prisma for migrations; same as DATABASE_URL unless
# you're behind a pooler like PgBouncer / Supabase).
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/problem_context_store?schema=public"

# -------- App --------
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -------- Auth (added in M2) --------
# AUTH_SECRET=""                     # `openssl rand -base64 32`
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
# EMAIL_FROM="noreply@localhost"
# RESEND_API_KEY=""

# -------- Queue / Redis (added in M5) --------
# REDIS_URL="redis://localhost:6379"

# -------- LLM (added in M6) --------
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-sonnet-4-6"
# OPENAI_API_KEY=""                  # used only for embeddings unless we swap to Voyage
# EMBEDDING_MODEL="text-embedding-3-small"

# -------- Object storage (added in M5) --------
# S3_ENDPOINT=""
# S3_BUCKET=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# -------- Observability (added in M10) --------
# SENTRY_DSN=""
