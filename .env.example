# =============================================================================
# Problem Context Store — environment variables
# Copy this file to `.env` and fill in any values you've changed from defaults.
# =============================================================================

# -------- Database --------
# Postgres connection string. The `pgvector` extension must be installed.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/problem_context_store?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/problem_context_store?schema=public"

# -------- App --------
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -------- Auth (M2) ---------------------------------------------------------
# Required. Generate one with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-real-secret"

# Required for cookie security in production. Leave commented for localhost.
# AUTH_URL="https://yourdomain.com"

# Magic-link sender — leave RESEND_API_KEY blank during dev to print the
# sign-in link to your `pnpm dev` terminal instead of sending an email.
# RESEND_API_KEY=""
EMAIL_FROM="Problem Context Store <onboarding@resend.dev>"

# Google OAuth — optional. If not set, the "Continue with Google" button is hidden.
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# -------- Queue / Redis (added in M5) ----------------------------------------
# REDIS_URL="redis://localhost:6379"

# -------- Intelligence: embeddings + LLM judge (M6 resolver) ----------------
# The resolver works in three modes:
#   1. No providers configured → rules only.
#   2. Embeddings provider → vector matching.
#   3. Embeddings + LLM judge → full pipeline.

# Free local default — install Ollama (https://ollama.com), then:
#     ollama pull nomic-embed-text
#     ollama pull llama3.1:8b
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_EMBEDDING_MODEL="nomic-embed-text"
# OLLAMA_LLM_MODEL="llama3.1:8b"

# Summarization model (M7). Used by the "Generate summary" button on the
# Problem detail page. Defaults to OLLAMA_LLM_MODEL if not set. The judge runs
# on every webhook (latency-sensitive) while summaries run on a button click
# (quality-sensitive) — so you may want them to be different models.
#
# Open-weights options, in rough quality-per-MB order:
#   qwen2.5:7b-instruct   (~4.7 GB, Apache 2.0)  best small-LLM for JSON + summaries
#   llama3.1:8b           (~4.6 GB, Llama)       solid all-rounder, what the judge uses
#   qwen2.5:3b-instruct   (~1.9 GB, Apache 2.0)  punches above its weight, fast
#   llama3.2:3b-instruct  (~2.0 GB, Llama)       stable JSON output, fast
#   phi3.5:3.8b           (~2.2 GB, MIT)         strong reasoning, sometimes verbose
# OLLAMA_SUMMARY_MODEL="llama3.1:8b"

# Paid alternatives — use these instead of (or alongside) Ollama. If both are
# set, EMBEDDINGS_PROVIDER / LLM_PROVIDER picks. Default auto-detect prefers
# Ollama, then OpenAI/Anthropic, then no-op.
# EMBEDDINGS_PROVIDER="ollama"   # or "openai"
# LLM_PROVIDER="ollama"           # or "anthropic"

# Paid embedding/LLM (only used if their providers are selected)
# OPENAI_API_KEY=""
# EMBEDDING_MODEL="text-embedding-3-small"
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-sonnet-4-5"
# ANTHROPIC_SUMMARY_MODEL="claude-sonnet-4-5"  # optional override for summaries

# -------- Object storage (added in M5) ---------------------------------------
# S3_ENDPOINT=""
# S3_BUCKET=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# -------- Observability (added in M10) ---------------------------------------
# SENTRY_DSN=""
