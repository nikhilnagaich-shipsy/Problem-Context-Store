{
  "name": "problem-context-store",
  "version": "0.1.0",
  "private": true,
  "description": "The customer-problem memory layer for B2B software companies.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @pcs/db prisma:generate",
    "db:push": "pnpm --filter @pcs/db prisma:push",
    "db:migrate": "pnpm --filter @pcs/db prisma:migrate",
    "db:studio": "pnpm --filter @pcs/db prisma:studio",
    "db:seed": "pnpm --filter @pcs/db seed",
    "db:reset": "pnpm --filter @pcs/db prisma:reset"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "prettier": "^3.3.3"
  }
}
